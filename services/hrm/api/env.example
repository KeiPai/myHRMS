# =============================================================================
# Hrm API Service - Environment Configuration
# =============================================================================
# Copy this file to .env and update with your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
DEBUG=true
NODE_ENV=development
RUN_MODE=startup
TZ=Asia/Ho_Chi_Minh
APP_ENV_APPLICATION_NAME=hrm
APP_ENV_APPLICATION_TIMEZONE=Asia/Ho_Chi_Minh
APP_ENV_LOGGER_FOLDER_PATH=./app_data
APP_ENV_SERVER_BASE_PATH=/api


# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
APP_ENV_DOMAIN=localhost

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
APP_ENV_HOST=0.0.0.0
APP_ENV_PORT=3012
APP_ENV_NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
APP_ENV_DATABASE_URL=postgresql://postgres:password@localhost:5432/hrm_db

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
APP_ENV_JWT_SECRET=a3e33eebd7e6aa3b8a454fa0dc89f3073ddf6a86c27679302c99c9e52b646c54
APP_ENV_JWT_ISSUER=veni-ai-platform
APP_ENV_JWT_AUDIENCE=veni-ai-services

# -----------------------------------------------------------------------------
# Keycloak Configuration (for OAuth login)
# -----------------------------------------------------------------------------
APP_ENV_KEYCLOAK_URL=http://localhost:18080
APP_ENV_KEYCLOAK_REALM=veni-ai
APP_ENV_KEYCLOAK_CLIENT_ID=veni-ai-platform

# -----------------------------------------------------------------------------
# MinIO Configuration (Object Storage)
# -----------------------------------------------------------------------------
APP_ENV_MINIO_ENDPOINT=localhost
APP_ENV_MINIO_PORT=19000
APP_ENV_MINIO_USE_SSL=false
APP_ENV_MINIO_ACCESS_KEY=minioadmin
APP_ENV_MINIO_SECRET_KEY=minioadmin
APP_ENV_MINIO_BUCKET_PREFIX=hrm

# -----------------------------------------------------------------------------
# Redis Configuration (Cache & Session Store)
# -----------------------------------------------------------------------------
APP_ENV_REDIS_URL=redis://localhost:16379

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
APP_ENV_API_URL=http://localhost:3012
APP_ENV_FRONTEND_URL=http://localhost:4175

# -----------------------------------------------------------------------------
# Shell API (for token exchange: Remote API → Shell API gRPC)
# -----------------------------------------------------------------------------
APP_ENV_SHELL_GRPC_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# APP_ENV_CORS_ORIGINS=http://localhost:5173,http://localhost:4175
